Screen {
    layout: vertical;
}

#header {
    height: 5;
    padding: 0 2;
}

#tab-bar {
    height: 1;
    padding: 0 1;
}

#search-bar {
    height: 1;
    padding: 0 1;
}

#sessions-pane {
    height: 1fr;
}

#session-list {
    width: 45;
    height: 1fr;
    min-height: 10;
}

.session-row {
    height: 1;
}

.group-header {
    height: 1;
    padding: 0 1;
}

#preview {
    width: 1fr;
    height: 1fr;
    padding: 0 1;
}

#footer {
    height: 1;
    dock: bottom;
    padding: 0 1;
}

#overview, #projects-view, #help-view {
    padding: 1 2;
}
